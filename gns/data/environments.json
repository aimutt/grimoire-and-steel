    {"name": "Cave", "description": "Natural caverns and grottoes inhabited by humanoids, vermin and lurking beasts."},
    {"name": "Rocky Cliffs", "description": "Steep crags and stony heights where winged predators and surefooted beasts dwell."},
    {"name": "Forested Hills", "description": "Rolling wooded country with game, predators and humanoid bands."},
    {"name": "Dark Forest", "description": "Deep, shadowed old-growth woodland thick with predators and lurking dangers."},
    {"name": "Desert", "description": "Arid wastes of sand and stone roamed by raiders, vermin and hardy beasts."},
    {"name": "Swamp", "description": "Fetid marsh and bog ruled by reptilian folk, oozes and biting things."},
    {"name": "Mountain Valley", "description": "High, cold valleys among the peaks, home to hardy beasts and great predators."},
    {"name": "Lowland Valley", "description": "Broad fertile lowlands and grassland with herd animals and the predators that follow them."}
